# ========================================
# 环境变量配置文件示例
# ========================================
#
# 本地开发：复制此文件为 .env 并修改配置
# 云托管部署：参考 .env.cloud 文件在云托管控制台配置环境变量
#

# ========== 数据库配置 ==========
# 本地开发环境
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12345678
DB_NAME=lottery_wxapp
DB_CHARSET=utf8mb4

# 云托管环境（仅供参考，实际在云托管控制台配置）
# DB_HOST=10.44.112.130
# DB_PASSWORD=AD9VhWrA

# JWT 配置
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# API 配置
API_V1_PREFIX=/api/v1
PROJECT_NAME=赛事推演预测系统

# 数据源配置（二选一）
# 选项 1: 使用第三方 API（推荐）
USE_API=true
API_FOOTBALL_KEY=your-api-key-here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# 选项 2: 使用爬虫（不推荐，有法律风险）
# USE_CRAWLER=true
# CRAWLER_INTERVAL_MINUTES=30
# CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True

# CORS 配置（开发环境）
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
